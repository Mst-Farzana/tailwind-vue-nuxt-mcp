{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "format": "prettier --write .",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "CI=true vitest run --coverage --reporter=junit",
    "check": "pnpm lint && pnpm format && pnpm nuxi typecheck && pnpm test",
    "check:fix": "pnpm lint:fix && pnpm format && pnpm nuxi typecheck"
  },
