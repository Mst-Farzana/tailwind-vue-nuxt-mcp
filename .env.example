# --------------------------
# DATABASE
# --------------------------
DATABASE_URL=postgresql://postgres:NEW_STRONG_PASSWORD@HOST:5432/DB_NAME

# --------------------------
# AUTH
# --------------------------
BETTER_AUTH_URL=https://your-production-domain.com
BETTER_AUTH_SECRET=RANDOM_LONG_SECURE_STRING_64CHARS

# --------------------------
# OAUTH / GITHUB
# --------------------------
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# --------------------------
# CLOUDINARY (Media Uploads)
# --------------------------
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=NEW_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=NEW_STRONG_SECRET

# --------------------------
# AI / LLM (OpenAI)
# --------------------------
OPENAI_API_KEY=sk-proj-NEW_SAFE_KEY
